@model ShoesForFeet.Models.Product

<h1>Add a New Product</h1>
<form method="post" asp-action="Add">
    <div>
        <label for="Name">Product Name:</label>
        <input id="Name" name="Name" value="@Model?.Name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div>
        <label for="ShoeSize">Shoe Size:</label>
        <input id="ShoeSize" name="ShoeSize" value="@Model?.ShoeSize" type="number" />
        <span asp-validation-for="ShoeSize" class="text-danger"></span>
    </div>

    <div>
        <label for="Price">Price:</label>
        <input id="Price" name="Price" value="@Model?.Price" type="number" step="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <button type="submit">Add Product</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}